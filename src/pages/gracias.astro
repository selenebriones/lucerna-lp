---
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Cotización Enviada! | Lucerna Energy">
  <main class="min-h-[90vh] bg-lucerna-blue flex flex-col items-center justify-center relative overflow-hidden py-32 px-4">
    <!-- Elementos de Iluminación y Decorativos -->
    <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-lucerna-accent/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-white/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-2xl mx-auto text-center relative z-10 scale-95 animate-[pulse_0.4s_ease-out_forwards]">
      
      <!-- Check Icon Premium -->
      <div class="w-28 h-28 bg-lucerna-accent rounded-full flex items-center justify-center mx-auto mb-10 shadow-[0_0_50px_rgba(255,184,0,0.4)] border border-lucerna-accent">
        <i class="ph-bold ph-check text-5xl text-lucerna-blue"></i>
      </div>
      
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-montserrat font-bold text-white mb-6 leading-tight tracking-tight">
        ¡Solicitud <br/><span class="text-lucerna-accent">Enviada!</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-gray-300 font-inter leading-relaxed mb-12">
        Hemos recibido tus datos correctamente. Nuestro equipo de ingenieros ya está analizando tu caso y se pondrá en contacto contigo a la brevedad.
      </p>
      
      <a href="/" class="inline-flex items-center justify-center gap-3 bg-white text-lucerna-blue font-bold font-inter text-lg px-12 py-5 rounded-full hover:bg-lucerna-accent hover:text-white transition-all duration-300 shadow-2xl hover:-translate-y-1 hover:shadow-white/20 group w-full md:w-auto">
        <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
        Volver a la página principal
      </a>
      
    </div>
  </main>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
