---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lucerna Energy | Independencia Energética" description="Ahorro y energía continua para tu hogar o industria.">
  
  <!-- 1. HERO SECTION (Premium, Video & Geo-Targeted) -->
  <section id="hero" class="relative h-screen min-h-[700px] flex items-center bg-lucerna-blue overflow-hidden">
    
    <!-- Video Background Cinematográfico -->
    <video 
      autoplay 
      loop 
      muted 
      playsinline 
      class="absolute inset-0 w-full h-full object-cover scale-[1.02]"
    >
      <source src="/hero.mp4" type="video/mp4" />
    </video>

    <!-- Extensión Global del Efecto Blur sobre el Video -->
    <div class="absolute inset-0 backdrop-blur-md pointer-events-none"></div>

    <!-- Efecto Malla Sutil (Raster Overlay) -->
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPjxyZWN0IHdpZHRoPSI0IiBoZWlnaHQ9IjQiIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSIvPjwvc3ZnPg==')] opacity-40 mix-blend-overlay pointer-events-none"></div>

    <!-- Radial Gradient Overlay -> Dramatismo y legibilidad -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_var(--tw-gradient-stops))] from-lucerna-blue via-lucerna-blue/80 to-transparent pointer-events-none"></div>
    
    <!-- Hero Content: Glassmorphism Card -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-32 mt-10">
      <div class="max-w-3xl backdrop-blur-md bg-lucerna-blue/10 p-10 lg:p-14 rounded-[2.5rem] border border-white/10 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.5)] relative overflow-hidden group hover:border-white/20 transition-all duration-700">
        
        <!-- Glow dinámico interno -->
        <div class="absolute -top-32 -left-32 w-80 h-80 bg-lucerna-accent/20 rounded-full blur-[80px] opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>

        <div class="relative z-10">
          <div class="inline-flex items-center gap-3 px-5 py-2.5 bg-lucerna-accent/10 border border-lucerna-accent/20 rounded-full text-lucerna-accent mt-2 font-bold text-xs tracking-widest uppercase mb-8 shadow-inner">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-lucerna-accent opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-lucerna-accent"></span>
            </span>
            Transición a Energía Positiva
          </div>

          <h1 class="text-5xl md:text-7xl font-montserrat font-bold text-white leading-tight mb-8" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-lucerna-accent to-yellow-200 drop-shadow-sm">Independencia</span> Energética para tu Hogar en Nuevo León
          </h1>
          <p class="text-lg md:text-xl font-inter text-gray-200 mb-10 leading-relaxed font-light">
            Especialistas en ingeniería fotovoltaica diseñada para vencer las altas tarifas de CFE y asegurar el confort de tu familia sin interrupciones.
          </p>
          <div class="flex flex-wrap gap-5">
            <a href="#contacto" class="inline-flex justify-center items-center px-8 py-4 text-lg font-bold rounded-full text-lucerna-blue bg-lucerna-accent hover:bg-yellow-400 hover:-translate-y-1 transition-all duration-300 shadow-xl shadow-lucerna-accent/40 group/btn">
              Cotizar Proyecto
              <i class="ph-bold ph-arrow-right ml-2 group-hover/btn:translate-x-1 transition-transform"></i>
            </a>
            <a href="#tecnologia" class="inline-flex justify-center items-center gap-3 px-8 py-4 text-lg font-bold rounded-full text-white bg-white/5 border border-white/20 hover:bg-white/15 hover:border-white/50 backdrop-blur-lg hover:-translate-y-1 transition-all duration-300">
              <i class="ph-duotone ph-play-circle text-2xl"></i> Ver Tecnología BIM
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. BENTO GRID: BENEFICIOS CON VALOR REAL -->
  <section id="beneficios" class="py-32 bg-lucerna-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20 relative">
        <span class="text-lucerna-accent font-bold tracking-widest uppercase text-sm mb-2 block">Diferenciales</span>
        <h2 class="text-4xl md:text-5xl font-montserrat font-bold text-lucerna-blue">Beneficios con Valor Real</h2>
      </div>
      
      <!-- Grid Desktop 3 columnas -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- 1 -->
        <div class="bg-white p-10 rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-gray-100/50 benefit-card">
          <div class="mb-6">
            <i class="ph-duotone ph-money text-6xl text-lucerna-accent"></i>
          </div>
          <h3 class="text-2xl font-bold font-montserrat text-lucerna-blue mb-3">Ahorro Económico</h3>
          <p class="text-gray-600 font-inter leading-relaxed">Reducción inmediata en facturación residencial ante CFE, con excedentes a tu favor.</p>
        </div>
        
        <!-- 2 -->
        <div class="bg-white p-10 rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-gray-100/50 benefit-card">
          <div class="mb-6">
            <i class="ph-duotone ph-trend-up text-6xl text-lucerna-accent"></i>
          </div>
          <h3 class="text-2xl font-bold font-montserrat text-lucerna-blue mb-3">Alto Retorno</h3>
          <p class="text-gray-600 font-inter leading-relaxed">Proyectos con ingeniería de alta precisión asegurando un ROI agresivo de 2 a 3 años.</p>
        </div>

        <!-- 3 -->
        <div class="bg-white p-10 rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-gray-100/50 benefit-card">
          <div class="mb-6">
            <i class="ph-duotone ph-shield-check text-6xl text-lucerna-accent"></i>
          </div>
          <h3 class="text-2xl font-bold font-montserrat text-lucerna-blue mb-3">Alta Durabilidad</h3>
          <p class="text-gray-600 font-inter leading-relaxed">Paneles con larga vida útil, bajo mantenimiento y garantías directas de fábrica.</p>
        </div>

        <!-- 4 -->
        <div class="bg-white p-10 rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-gray-100/50 benefit-card">
          <div class="mb-6">
            <i class="ph-duotone ph-leaf text-6xl text-lucerna-accent"></i>
          </div>
          <h3 class="text-2xl font-bold font-montserrat text-lucerna-blue mb-3">Sustentabilidad</h3>
          <p class="text-gray-600 font-inter leading-relaxed">Energía limpia que reduce tu huella de carbono impulsando un estilo de vida consciente.</p>
        </div>

        <!-- 5 -->
        <div class="bg-white p-10 rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-gray-100/50 benefit-card">
          <div class="mb-6">
            <i class="ph-duotone ph-lightning text-6xl text-lucerna-accent"></i>
          </div>
          <h3 class="text-2xl font-bold font-montserrat text-lucerna-blue mb-3">Confiabilidad</h3>
          <p class="text-gray-600 font-inter leading-relaxed">Respaldo ante fallas de red en las temporadas más críticas del clima en el norte del país.</p>
        </div>

        <!-- 6 -->
        <div class="bg-white p-10 rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-gray-100/50 benefit-card">
          <div class="mb-6">
            <i class="ph-duotone ph-house-line text-6xl text-lucerna-accent"></i>
          </div>
          <h3 class="text-2xl font-bold font-montserrat text-lucerna-blue mb-3">Plusvalía</h3>
          <p class="text-gray-600 font-inter leading-relaxed">Incremento directo en el valor de mercado de tu propiedad de manera instantánea.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 2.5 SECCIÓN: PANELES SOLARES PARA CASAS (Split creativo) -->
  <section id="residencial" class="py-32 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-16">
        
        <!-- Contenedor Visual Creativo -->
        <div class="w-full lg:w-1/2 relative pb-10 lg:pb-0">
          <div class="absolute inset-0 bg-gradient-to-tr from-lucerna-blue/5 to-lucerna-accent/10 rounded-[3rem] transform -rotate-3 scale-105"></div>
          <div class="relative bg-gray-100 rounded-[3rem] overflow-hidden shadow-2xl group min-h-[500px]">
             <img src="/residencia.jpeg" alt="Paneles Residenciales" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-[2000ms]" onerror="this.onerror=null; this.src='https://placehold.co/800x1200/F4F7F9/003366?text=Arquitectura+Limpia'" />
             <!-- Insignia glass flotante -->
             <div class="absolute bottom-8 left-8 max-w-[80%] bg-white/80 backdrop-blur-md border border-white p-6 rounded-2xl opacity-0 group-hover:opacity-100 transition-all duration-700 translate-y-8 group-hover:translate-y-0 shadow-xl">
               <div class="flex items-center gap-4">
                 <div class="h-12 w-12 bg-lucerna-accent rounded-full flex items-center justify-center flex-shrink-0 shadow-lg">
                   <i class="ph-bold ph-house-line text-lucerna-blue text-xl"></i>
                 </div>
                 <div>
                   <p class="font-montserrat font-bold text-lucerna-blue whitespace-nowrap">Integración Estética</p>
                   <p class="font-inter text-sm text-gray-600">Diseño limpio y oculto</p>
                 </div>
               </div>
             </div>
          </div>
        </div>

        <!-- Contenido Textual -->
        <div class="w-full lg:w-1/2">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 shadow-sm rounded-full text-lucerna-blue font-bold tracking-widest uppercase text-xs mb-8">
            <i class="ph-fill ph-sun text-lucerna-accent text-base"></i>
            Residencial Premium
          </div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-montserrat font-bold text-lucerna-blue mb-8 leading-tight">
            Paneles solares para casas
          </h2>
          <p class="text-xl text-gray-600 font-inter leading-relaxed mb-6">
            Implementamos energía solar de alto rendimiento mediante paneles diseñados explícitamente para cubrir tu demanda energética, salvaguardando la operatividad de climas y confort <span class="font-bold text-lucerna-blue bg-lucerna-accent/10 px-2 py-1 rounded-md">sin comprometer la estética de tu propiedad.</span>
          </p>
          <div class="flex items-start gap-4 p-6 bg-lucerna-gray rounded-2xl border border-gray-100 shadow-inner mt-8">
            <i class="ph-duotone ph-battery-charging text-4xl text-lucerna-accent flex-shrink-0 mt-1"></i>
            <p class="text-base text-gray-600 font-inter leading-relaxed">
              Nuestros sistemas pueden integrarse nativamente con baterías solares y sistemas de almacenamiento profundo <span class="font-bold text-lucerna-blue">para asegurar el respaldo y la continuidad total de tu hogar</span> ante cualquier falla en la red.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. COMPONENTE: CALCULADORA DE AHORRO SOLAR -->
  <section id="calculadora" class="py-32 bg-lucerna-gray relative overflow-hidden">
    <!-- Deco Background -->
    <div class="absolute -top-40 right-[-10%] w-[50rem] h-[50rem] bg-lucerna-accent/10 rounded-full blur-[100px]"></div>
    
    <div class="max-w-6xl mx-auto px-4 relative z-10">
      <!-- Contenedor Glassmorphism -->
      <div class="bg-white/80 backdrop-blur-xl border border-white p-8 md:p-14 lg:p-20 rounded-[2.5rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.05)]">
        
        <div class="flex flex-col lg:flex-row gap-16 items-stretch">
          
          <!-- Input Area -->
          <div class="w-full lg:w-1/2 flex flex-col justify-center">
            <h2 class="text-3xl lg:text-5xl font-montserrat font-bold text-lucerna-blue mb-6 leading-tight">Proyecta tu Ahorro</h2>
            
            <label for="monto-recibo" class="block font-bold font-inter text-gray-600 mb-3 tracking-wide">
              Monto promedio de tu recibo bimestral (MXN)
            </label>
            <div class="relative mb-8">
              <span class="absolute inset-y-0 left-0 flex items-center pl-6 text-lucerna-blue font-bold text-2xl">$</span>
              <input type="number" id="monto-recibo" placeholder="4500" class="w-full bg-white border-2 border-gray-100 text-lucerna-blue text-3xl font-bold font-montserrat rounded-[1.5rem] focus:ring-4 focus:ring-lucerna-accent/20 focus:border-lucerna-accent block pl-14 pr-6 py-6 outline-none transition-all shadow-inner" />
            </div>
            
            <button id="btn-calcular" class="w-full py-5 bg-lucerna-blue text-white text-lg font-bold rounded-full hover:bg-sky-900 transition-colors shadow-lg active:scale-[0.98]">
              Calcular Ahorro Potencial
            </button>
          </div>

          <!-- Result Area -->
          <div class="w-full lg:w-1/2 flex flex-col items-center justify-center bg-gray-50 rounded-[2rem] p-10 text-center border-2 border-dashed border-gray-200 relative min-h-[400px]">
            
            <div id="resultado-vacio" class="text-gray-400 font-inter flex flex-col items-center gap-4 transition-all duration-300">
                <i class="ph-duotone ph-calculator text-6xl opacity-50"></i>
                <p>Ingresa tu monto para conocer tu ROI</p>
            </div>

            <div id="resultado-lleno" class="hidden w-full flex-col items-center">
              <p class="font-inter text-gray-500 font-bold mb-2 uppercase tracking-wide opacity-0 calc-result translate-y-4">Tu ahorro estimado anual es de:</p>
              <div class="text-5xl lg:text-6xl font-montserrat font-bold text-lucerna-accent mb-6 opacity-0 calc-result translate-y-4 flex items-baseline gap-2">
                <span class="text-3xl text-gray-400 font-light">$</span>
                <span id="ahorro-anual">0</span>
              </div>
              
              <!-- Graphic Bar Chart Tailwind -->
              <div class="flex items-end justify-center gap-12 h-36 w-full opacity-0 calc-result border-b border-gray-200 pb-4 mb-6">
                <!-- Antes -->
                <div class="flex flex-col items-center gap-3">
                  <div class="w-20 bg-gray-300 rounded-t-xl transition-all duration-1000 ease-out flex items-end justify-center pb-2" style="height: 100%;">
                    <span class="text-gray-500 font-bold font-inter text-xs">100%</span>
                  </div>
                  <span class="text-xs font-bold text-gray-500 uppercase tracking-widest">Sin Lucerna</span>
                </div>
                <!-- Después (Animado) -->
                <div class="flex flex-col items-center gap-3">
                  <div id="bar-despues" class="w-20 bg-lucerna-accent rounded-t-xl shadow-lg shadow-lucerna-accent/30 transition-all duration-1000 ease-out flex items-start justify-center pt-2 overflow-hidden" style="height: 0%;">
                    <span class="text-white font-bold font-inter text-xs block opacity-0 calc-result">5%</span>
                  </div>
                  <span class="text-xs font-bold text-lucerna-blue uppercase tracking-widest">Con Lucerna</span>
                </div>
              </div>
              
              <!-- Dynamic CTA revealed after calculation -->
              <button id="btn-cta-result" onclick="document.getElementById('contacto')?.scrollIntoView({behavior: 'smooth'})" class="opacity-0 calc-result mt-2 inline-flex justify-center items-center w-full px-8 py-4 text-base font-bold rounded-full text-white bg-lucerna-blue hover:bg-gray-800 shadow-xl hover:-translate-y-1 transition-all group">
                Solicitar Estudio Personalizado
                <i class="ph-bold ph-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
              </button>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. SECCIÓN: CONTINUIDAD Y ALMACENAMIENTO -->
  <section id="almacenamiento" class="bg-white flex flex-col lg:flex-row min-h-[70vh]">
    <!-- Contenido 50% Texto -->
    <div class="w-full lg:w-1/2 p-12 md:p-24 lg:p-32 flex flex-col justify-center bg-gray-50">
      <div class="max-w-xl mx-auto lg:mx-0">
        <h2 class="text-4xl md:text-5xl font-montserrat font-bold text-lucerna-blue mb-8 leading-tight">
          Protección Contra Interrupciones
        </h2>
        <p class="text-xl text-gray-600 font-inter mb-8 leading-relaxed">
          Asegura la continuidad del suministro en tu hogar ante cualquier falla temporal o general en la red.
        </p>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start gap-4">
          <i class="ph-duotone ph-battery-charging text-4xl text-lucerna-accent flex-shrink-0"></i>
          <p class="text-base text-gray-600 font-inter leading-relaxed">
            Nuestras soluciones de almacenamiento inteligente (tipo Powerwall) actúan en fracción de segundos, garantizando que el confort y la seguridad de tu familia nunca se vean comprometidos durante apagones.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Contenido 50% Imagen Técnica (Con Máscara Premium) -->
    <div class="w-full lg:w-1/2 relative overflow-hidden group min-h-[400px] lg:min-h-auto bg-lucerna-blue">
      
      <!-- Imagen original con filtros fuertes para disimular calidad -->
      <img src="/powerwall.jpeg" alt="Sistema de Almacenamiento y Baterías" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-[3000ms] opacity-50 mix-blend-luminosity grayscale contrast-125" onerror="this.onerror=null; this.src='https://placehold.co/1000x1200/101828/FFFFFF?text=Instalaci%C3%B3n+Residencial+Powerwall'" />
      
      <!-- Overlay Dual para lograr un tinte Duotone corporativo y esconder el ruido de la foto -->
      <div class="absolute inset-0 bg-lucerna-blue/50 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-lucerna-blue via-transparent to-lucerna-blue/30 opacity-90"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPjxyZWN0IHdpZHRoPSI0IiBoZWlnaHQ9IjQiIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSIvPjwvc3ZnPg==')] opacity-30 mix-blend-overlay"></div>

      <!-- Placa flotante decorativa para desviar la atención hacia un elemento de UI limpio -->
      <div class="absolute inset-8 border border-white/10 rounded-3xl pointer-events-none flex items-center justify-center backdrop-blur-[2px] bg-white/5 transition-all duration-700 group-hover:bg-white/10 group-hover:border-white/30">
         <div class="flex flex-col items-center gap-4 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-700 translate-y-4 group-hover:translate-y-0">
           <div class="w-16 h-16 rounded-full bg-lucerna-accent/20 flex items-center justify-center backdrop-blur-md border border-lucerna-accent/30 shadow-[0_0_30px_rgba(255,184,0,0.3)]">
             <i class="ph-duotone ph-lightning text-3xl text-lucerna-accent animate-pulse"></i>
           </div>
           <p class="font-montserrat font-bold text-white tracking-widest uppercase text-sm mt-2">Respaldo 24/7</p>
         </div>
      </div>
    </div>
  </section>

  <!-- 5. SECCIÓN: POR QUÉ ELEGIRNOS -->
  <section id="por-que-elegirnos" class="py-24 relative bg-gray-50/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-24 items-start">
        
        <!-- Izquierda: Título y Párrafo principal -->
        <div class="w-full lg:w-5/12 lg:sticky lg:top-32">
          <h2 class="text-5xl md:text-6xl font-montserrat font-bold text-lucerna-blue mb-8 leading-tight tracking-tight">
            ¿Por qué<br/> elegirnos?
          </h2>
          <p class="text-base text-gray-700 font-inter leading-relaxed">
            Contamos con la infraestructura necesaria para operar en las zonas residenciales de mayor demanda en el estado, garantizando sistemas que cada panel solar soporte las condiciones climáticas de la región.
          </p>
        </div>

        <!-- Derecha: Listado de Beneficios Técnicos -->
        <div class="w-full lg:w-7/12 flex flex-col gap-6 mt-4 lg:mt-0">
          
          <div class="flex gap-6 p-5 rounded-3xl hover:bg-white hover:shadow-lg transition-all duration-300 border border-transparent hover:border-gray-100 group">
            <div class="flex-shrink-0 mt-1">
              <div class="w-14 h-14 rounded-2xl bg-white border border-gray-100 shadow-sm flex items-center justify-center group-hover:scale-110 group-hover:border-lucerna-accent/30 group-hover:bg-lucerna-gray transition-all duration-300">
                <i class="ph-duotone ph-certificate text-3xl text-lucerna-blue group-hover:text-lucerna-accent transition-colors"></i>
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold font-montserrat text-lucerna-blue mb-2">Ingeniería con experiencia</h3>
              <p class="text-gray-600 font-inter leading-relaxed">
                Más de 10 años de experiencia en el diseño e implementación de soluciones de energía fotovoltaica.
              </p>
            </div>
          </div>
          
          <div class="flex gap-6 p-5 rounded-3xl hover:bg-white hover:shadow-lg transition-all duration-300 border border-transparent hover:border-gray-100 group">
            <div class="flex-shrink-0 mt-1">
              <div class="w-14 h-14 rounded-2xl bg-white border border-gray-100 shadow-sm flex items-center justify-center group-hover:scale-110 group-hover:border-lucerna-accent/30 group-hover:bg-lucerna-gray transition-all duration-300">
                <i class="ph-duotone ph-user-focus text-3xl text-lucerna-blue group-hover:text-lucerna-accent transition-colors"></i>
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold font-montserrat text-lucerna-blue mb-2">Gestión personalizada</h3>
              <p class="text-gray-600 font-inter leading-relaxed">
                Project Manager asignado para coordinar desde la planeación técnica hasta la interconexión.
              </p>
            </div>
          </div>

          <div class="flex gap-6 p-5 rounded-3xl hover:bg-white hover:shadow-lg transition-all duration-300 border border-transparent hover:border-gray-100 group">
            <div class="flex-shrink-0 mt-1">
              <div class="w-14 h-14 rounded-2xl bg-white border border-gray-100 shadow-sm flex items-center justify-center group-hover:scale-110 group-hover:border-lucerna-accent/30 group-hover:bg-lucerna-gray transition-all duration-300">
                <i class="ph-duotone ph-compass-tool text-3xl text-lucerna-blue group-hover:text-lucerna-accent transition-colors"></i>
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold font-montserrat text-lucerna-blue mb-2">Precisión técnica</h3>
              <p class="text-gray-600 font-inter leading-relaxed">
                Uso de metodología BIM para asegurar instalaciones estéticas, seguras y eficientes.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- 6. BANNER CTA FINAL (con Fondo Dinámico y Efecto Typo) -->
  <section class="py-32 relative overflow-hidden group">
    <!-- Fondo de Imagen Creativo -->
    <img src="/residencia-banner.jpeg" alt="Residencia Lucerna" class="absolute inset-0 w-full h-full object-cover grayscale opacity-90 mix-blend-luminosity group-hover:scale-105 transition-transform duration-[3000ms]" onerror="this.onerror=null; this.src='https://placehold.co/1920x600/003366/FFFFFF?text=Residencial'" />
    
    <!-- Filtros de Contraste Corporativo -->
    <div class="absolute inset-0 bg-lucerna-blue/80 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-lucerna-blue via-lucerna-blue/70 to-lucerna-blue/90"></div>
    
    <div class="max-w-5xl mx-auto px-4 text-center relative z-10 flex flex-col items-center">
      <!-- Flex contenedor con gap solucionando el espaciado y colapsado html -->
      <h2 id="typo-text-container" class="text-3xl md:text-4xl lg:text-5xl font-montserrat font-bold text-white mb-16 leading-tight tracking-tight min-h-[120px] lg:min-h-[150px] flex flex-wrap justify-center gap-x-[0.25em] gap-y-2">
        <!-- JavaScript agregará cada palabra aquí -->
      </h2>
      
      <a href="#contacto" class="bg-white text-lucerna-blue font-bold font-inter text-lg px-24 py-4 rounded-full hover:bg-lucerna-accent hover:text-white transition-all duration-300 shadow-[0_0_40px_rgba(255,255,255,0.1)] hover:-translate-y-1 hover:shadow-[0_0_40px_rgba(255,184,0,0.4)]">
        Conocer
      </a>
    </div>

    <!-- Script de Efecto Typo (Animación Cinética de Texto) -->
    <script is:inline>
      const initTypo = () => {
        const textToAnimate = "Optimiza tu consumo eléctrico con la ingeniería eficiente y de alto rendimiento de Lucerna Energy.";
        const container = document.getElementById('typo-text-container');
        if(!container || container.dataset.init) return;
        container.dataset.init = "true";
        
        // Dividir el texto en palabras
        const words = textToAnimate.split(" ");
        container.innerHTML = ''; 
        
        words.forEach(word => {
          const span = document.createElement('span');
          span.textContent = word;
          span.style.opacity = '0';
          span.style.display = 'inline-block';
          span.style.transform = 'translateY(20px)';
          span.className = 'typo-word';
          container.appendChild(span);
        });

        // Intentar iniciar GSAP (con reintentos en caso de carga asíncrona en Astro)
        const checkAndAnimate = (attempts = 0) => {
          if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);
            gsap.to('.typo-word', {
              scrollTrigger: {
                trigger: '#typo-text-container',
                start: 'top 85%',
              },
              opacity: 1,
              y: 0,
              duration: 0.6,
              stagger: 0.08,
              ease: "back.out(1.5)"
            });
          } else if (attempts < 20) {
            setTimeout(() => checkAndAnimate(attempts + 1), 100);
          } else {
            // Nativo Fallback seguro
            document.querySelectorAll('.typo-word').forEach(w => {
              w.style.opacity = '1';
              w.style.transform = 'translateY(0)';
            });
          }
        };
        checkAndAnimate();
      };

      // Iniciar cuando el DOM este listo y asegurar reintentos si GSAP desde layout tarda
      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initTypo();
      } else {
        window.addEventListener('DOMContentLoaded', initTypo);
      }
    </script>
  </section>

  <!-- Lógica de Animación & Calculadora GSAP + ScrollTrigger -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      
      // ===== GSAP & SCROLLTRIGGER INITIALIZATION =====
      if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        gsap.registerPlugin(ScrollTrigger);

        // 1. Animar Hero Elements
        gsap.from('#hero h1, #hero p, #hero div.flex', {
          y: 40,
          opacity: 0,
          duration: 1.2,
          stagger: 0.2,
          ease: 'power3.out',
          delay: 0.1
        });

        // 2. Animar Tarjetas de Beneficios (Staggered)
        gsap.from('.benefit-card', {
          scrollTrigger: {
            trigger: '#beneficios',
            start: 'top 75%'
          },
          y: 30,
          opacity: 0,
          duration: 0.8,
          stagger: 0.15,
          ease: 'power2.out'
        });
        
        // 3. Animar Elementos del Almacenamiento
        gsap.from('#almacenamiento h2, #almacenamiento p, #almacenamiento div.bg-white', {
          scrollTrigger: {
            trigger: '#almacenamiento',
            start: 'top 75%'
          },
          y: 30,
          opacity: 0,
          duration: 0.8,
          stagger: 0.2,
          ease: 'power2.out'
        });
      }

      // ===== CALCULADORA LÓGICA =====
      const btnCalcular = document.getElementById('btn-calcular');
      const inputMonto = document.getElementById('monto-recibo');
      const containerVacio = document.getElementById('resultado-vacio');
      const containerLleno = document.getElementById('resultado-lleno');
      
      const targetAhorro = document.getElementById('ahorro-anual');
      const resultElements = document.querySelectorAll('.calc-result');
      const barDespues = document.getElementById('bar-despues');

      btnCalcular.addEventListener('click', () => {
        const monto = parseFloat(inputMonto.value);
        
        if (!isNaN(monto) && monto > 0) {
          // Ahorro Anual = (Monto * 6) * 0.95
          const ahorroAnual = (monto * 6) * 0.95;

          // Toggle vistas del resultado
          containerVacio.style.display = 'none';
          containerLleno.classList.remove('hidden');
          containerLleno.classList.add('flex');

          if (typeof gsap !== 'undefined') {
            // Reset state
            gsap.set(resultElements, { opacity: 0, y: 15 });
            barDespues.style.height = '0%';
            
            // Animar Contenedores de Resultado
            gsap.to(resultElements, {
              opacity: 1, 
              y: 0, 
              stagger: 0.15,
              duration: 0.8,
              ease: "back.out(1.5)"
            });

            // Animar números del ahorro
            gsap.to(targetAhorro, {
              innerHTML: Math.round(ahorroAnual),
              duration: 1.5,
              ease: "power2.out",
              snap: { innerHTML: 1 },
              onUpdate: function() {
                targetAhorro.innerHTML = Number(targetAhorro.innerHTML).toLocaleString('es-MX');
              }
            });

            // Animar gráfica CSS
            setTimeout(() => {
              barDespues.style.height = '15%'; // Simulamos el recibo mínimo de CFE a nivel visual
            }, 500);

          } else {
            // Fallback sin GSAP
            resultElements.forEach(el => {
              el.style.opacity = 1;
              el.style.transform = 'translateY(0)';
            });
            targetAhorro.innerText = Math.round(ahorroAnual).toLocaleString('es-MX');
            barDespues.style.height = '15%';
          }
        }
      });
      
      inputMonto.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          btnCalcular.click();
        }
      });
    });
  </script>

</Layout>
