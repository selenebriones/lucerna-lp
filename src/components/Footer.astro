---
---
<footer id="contacto" class="w-full relative overflow-hidden">
  
  <!-- CONTENEDOR PRINCIPAL: Formulario y Contacto (Light Theme) -->
  <div class="bg-white text-lucerna-blue py-16 relative w-full">
    <!-- Efecto Decorativo de Fondo -->
    <div class="absolute -top-[50%] -right-[10%] w-[800px] h-[800px] bg-lucerna-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        
        <!-- Info de Contacto (Columna Izquierda 4/12) -->
        <div class="flex flex-col gap-6 lg:col-span-4">
          <!-- Logo Color -->
          <img src="lucerna-logo-n.png\" alt="Lucerna Energy Logo" class="w-48 md:w-56 h-auto object-contain object-left mb-2 opacity-90" onerror="this.onerror=null; this.src='https://placehold.co/200x60/000000/FFFFFF?text=Lucerna+Energy&font=montserrat'" />
          <div>
            <h3 class="text-2xl font-montserrat font-bold text-lucerna-blue mb-2">Hablemos de energía</h3>
            <p class="font-inter text-gray-600 leading-relaxed text-sm">
              Estamos listos para transformar la manera en que consumes electricidad con ingeniería especializada.
            </p>
          </div>
          
          <div class="space-y-4 font-inter text-gray-700 mt-4 text-sm md:text-base">
            <div class="flex items-start gap-3">
               <i class="ph-duotone ph-map-pin text-2xl text-lucerna-accent shrink-0 mt-0.5"></i>
               <p>Av. Ricardo Margain 335,<br/>Valle del Campestre,<br/>San Pedro Garza García, N.L.</p>
            </div>
            <a href="mailto:sales@lucernaenergy.com" class="flex items-center gap-3 hover:text-lucerna-accent transition-colors duration-300 group">
              <i class="ph-duotone ph-envelope text-2xl text-lucerna-accent group-hover:scale-110 transition-transform"></i>
              sales@lucernaenergy.com
            </a>
            <a href="tel:8119990082" class="flex items-center gap-3 hover:text-lucerna-accent transition-colors duration-300 group">
              <i class="ph-duotone ph-phone text-2xl text-lucerna-accent group-hover:scale-110 transition-transform"></i>
              81 1999 0082
            </a>
          </div>
        </div>

        <!-- Formulario de Contacto (Columna Derecha 8/12) -->
        <div class="lg:col-span-8 bg-gray-50 border border-gray-200 p-8 md:p-12 rounded-[2.5rem] shadow-xl relative">
          <h3 class="text-3xl font-montserrat font-bold text-lucerna-blue mb-8">Cotiza tu Proyecto</h3>
          
          <form class="grid grid-cols-1 md:grid-cols-2 gap-6" action="#" method="POST" id="main-contact-form">
            
            <div class="md:col-span-2">
              <label for="nombre" class="block text-sm font-inter text-gray-700 mb-2">Nombre y Apellido *</label>
              <input type="text" id="nombre" name="nombre" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 text-lucerna-blue font-inter focus:outline-none focus:border-lucerna-accent focus:ring-1 focus:ring-lucerna-accent transition-all placeholder-gray-400 shadow-sm" placeholder="Ej. Juan Pérez" required>
            </div>

            <div>
              <label for="email" class="block text-sm font-inter text-gray-700 mb-2">Correo electrónico *</label>
              <input type="email" id="email" name="email" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 text-lucerna-blue font-inter focus:outline-none focus:border-lucerna-accent focus:ring-1 focus:ring-lucerna-accent transition-all placeholder-gray-400 shadow-sm" placeholder="Tu correo electrónico" required>
            </div>

            <div>
              <label for="telefono" class="block text-sm font-inter text-gray-700 mb-2">Número de teléfono *</label>
              <input type="tel" id="telefono" name="telefono" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 text-lucerna-blue font-inter focus:outline-none focus:border-lucerna-accent focus:ring-1 focus:ring-lucerna-accent transition-all placeholder-gray-400 shadow-sm" placeholder="A 10 dígitos" required>
            </div>

            <div class="md:col-span-2 relative">
              <label for="solucion" class="block text-sm font-inter text-gray-700 mb-2">Tipo de solución *</label>
              <select id="solucion" name="solucion" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 text-lucerna-blue font-inter focus:outline-none focus:border-lucerna-accent hover:border-gray-300 cursor-pointer transition-all appearance-none shadow-sm" required>
                <option value="" disabled selected>Selecciona la solución deseada...</option>
                <option value="paneles-solares-casa">Paneles solares para casa</option>
                <option value="energia-fotovoltaica">Energía Solar Fotovoltaica</option>
                <option value="almacenamiento-energia">Sistemas de Almacenamiento de Energía</option>
                <option value="motores-turbinas-gas">Generación con Motores y Turbinas a Gas Natural</option>
                <option value="soluciones-hibridas">Soluciones híbridas</option>
                <option value="microredes">Microredes</option>
              </select>
              <!-- Custom chevron for Select -->
              <i class="ph-bold ph-caret-down absolute right-5 top-[52px] text-gray-400 pointer-events-none"></i>
            </div>

            <div class="md:col-span-2">
              <label for="ciudad" class="block text-sm font-inter text-gray-700 mb-2">Ciudad *</label>
              <input type="text" id="ciudad" name="ciudad" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-4 text-lucerna-blue font-inter focus:outline-none focus:border-lucerna-accent focus:ring-1 focus:ring-lucerna-accent transition-all placeholder-gray-400 shadow-sm" placeholder="Ej. Monterrey, N.L." required>
            </div>

            <!-- Submit Button -->
            <div class="md:col-span-2 mt-6">
              <button type="submit" class="w-full bg-lucerna-blue text-white font-bold font-montserrat text-lg py-4 rounded-xl hover:bg-sky-900 transition-all duration-300 shadow-xl hover:-translate-y-1">
                Enviar Solicitud
              </button>
              <p class="text-xs text-center text-gray-500 mt-4 leading-relaxed tracking-wide">Tus datos están protegidos. No hacemos spam.</p>
            </div>
            
          </form>
        </div>
      </div>
    </div>
  </div>
  
  <div class="bg-[#F6F6F6] text-lucerna-blue w-full border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-center items-center text-sm font-inter text-gray-600 gap-4">
      <p>&copy; {new Date().getFullYear()} Lucerna Energy. Todos los derechos reservados.</p>
    </div>
  </div>

  <!-- Chatbot Script -->
  <script src="https://conversia.com.mx/assets/js/chatbot.js" id="chatbot-js"></script>
  <!-- Limpiar CSS del chatbot -->
  <link rel="stylesheet" href="chatbot-clean.css\">

  <script is:inline>
      // Destruir el CSS problemático sin importar cómo y cuándo se inyecte
      const watcher = new MutationObserver(() => {
          document.querySelectorAll('link[href*="chatbot.css"]').forEach(link => {
              // Permitir solo nuestra versión local limpia
              if (!link.href.includes('/chatbot-clean.css')) {
                  link.disabled = true;
                  link.remove();
              }
          });
      });
      watcher.observe(document.documentElement, { childList: true, subtree: true });

      CHATKODEX.init({
          host: window.location.host,
          key: 'ynUPRVWTtMihM'
      });
  </script>

  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NBJT5HR9" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
</footer>


<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("main-contact-form");
    if (!form) return;

    // Prevenir el comportamiento de números raros en input telefono
    const inputTelefono = document.getElementById("telefono");
    inputTelefono.addEventListener('input', function() {
      this.value = this.value.replace(/[^0-9+\-\s()]/g, '');
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault(); // Prevenimos salto de página

      // Extracción limpia
      const nombre = document.getElementById("nombre").value.trim();
      const email = document.getElementById("email").value.trim();
      const telefono = document.getElementById("telefono").value.trim();
      const solucionNode = document.getElementById("solucion");
      const solucion = solucionNode.options[solucionNode.selectedIndex].text; // Queremos el texto 'legible' de la opción, no el slug
      const solucionValue = document.getElementById("solucion").value;
      const ciudad = document.getElementById("ciudad").value.trim();

      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;

      // === VALIDACIONES FRONT-END ===
      if (!nombre || !email || !solucionValue || !ciudad || !telefono) {
        alert("Por favor, completa todos los campos requeridos para poder contactarte adecuadamente.");
        return;
      }

      // Validacion de Formato de Email
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        alert("Por favor entra un dirección de correo electrónico válida (ej: correo@empresa.com)");
        return;
      }

      // Validación Teléfono Comercial (10 a 14 dígitos en general)
      const sanitizedPhone = telefono.replace(/[^0-9]/g, '');
      if (sanitizedPhone.length < 10) {
        alert("Por favor ingresa un número de teléfono válido e incluye tu clave LADA, mínimo a 10 dígitos.");
        return;
      }

      // === ESTADO LOADING ===
      btn.disabled = true;
      btn.innerHTML = `Enviando Solicitud...`;
      btn.classList.add('opacity-70', 'cursor-wait');

      // === ENVIO AJAX PHP ===
      try {
        const response = await fetch('/paneles-solares-residenciales/sendmail.php', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ nombre, email, telefono, solucion, ciudad })
        });

        // Esperamos exito real desde el status Code HTTP de PHP
        if (response.ok) {
          // Exito! Limpiamos e inyectamos redicción suave. En Localhost no envia mail a menos q configures postfix
          form.reset();
          window.location.href = "/paneles-solares-residenciales/gracias";
        } else {
          // Ha ocurrido un error en php (por ejemplo funcion mail() dio false en localhost)
          alert("ocurrió un error y que intente de nuevo.");
          resetButton();
        }
      } catch (error) {
        // Error catastrófico de red CORS etc
        alert("ocurrió un error y que intente de nuevo.");
        resetButton();
      }

      function resetButton() {
        btn.disabled = false;
        btn.innerHTML = originalText;
        btn.classList.remove('opacity-70', 'cursor-wait');
      }
    });
  });
</script>
