---
---
<footer class="bg-lucerna-blue text-white py-16 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Info de Contacto -->
      <div class="flex flex-col gap-4">
        <img src="/lucerna-logo.png" alt="Lucerna Energy Logo" class="h-12 w-auto object-contain object-left mb-2 opacity-90 brightness-0 invert" style="filter: brightness(0) invert(1);" />
        <h3 class="text-xl font-montserrat font-bold text-lucerna-accent mb-2">Contacto</h3>
        <p class="font-inter text-gray-200 leading-relaxed">
          Av. Ricardo Margain 335,<br/>
          Valle del Campestre,<br/>
          San Pedro Garza García, N.L.
        </p>
        <a href="mailto:info@lucernaenergy.mx" class="inline-flex items-center gap-2 hover:text-lucerna-accent transition-colors duration-300 font-inter text-gray-200">
          <i class="ph ph-envelope text-xl"></i>
          info@lucernaenergy.mx
        </a>
      </div>

      <!-- Enlaces Rápidos -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xl font-montserrat font-bold text-lucerna-accent mb-4">Enlaces Rápidos</h3>
        <ul class="space-y-3 font-inter text-gray-200">
          <li>
            <a href="#beneficios" class="hover:text-lucerna-accent hover:pl-2 transition-all duration-300 block">Beneficios</a>
          </li>
          <li>
            <a href="#ingenieria" class="hover:text-lucerna-accent hover:pl-2 transition-all duration-300 block">Ingeniería</a>
          </li>
          <li>
            <a href="#calculadora" class="hover:text-lucerna-accent hover:pl-2 transition-all duration-300 block">Calculadora</a>
          </li>
        </ul>
      </div>

      <!-- Legales -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xl font-montserrat font-bold text-lucerna-accent mb-4">Legales</h3>
        <ul class="space-y-3 font-inter text-gray-200">
          <li>
            <a href="/privacidad" class="hover:text-lucerna-accent hover:pl-2 transition-all duration-300 block">Aviso de Privacidad</a>
          </li>
          <li>
            <a href="/terminos" class="hover:text-lucerna-accent hover:pl-2 transition-all duration-300 block">Términos y Condiciones</a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/20 mt-16 pt-8 flex flex-col md:flex-row justify-between items-center text-sm font-inter text-gray-400 gap-4">
      <p>&copy; {new Date().getFullYear()} Lucerna Energy. Todos los derechos reservados.</p>
      <div class="flex gap-4">
        <a href="#" class="hover:text-lucerna-accent transition-colors duration-300"><i class="ph ph-facebook-logo text-2xl"></i></a>
        <a href="#" class="hover:text-lucerna-accent transition-colors duration-300"><i class="ph ph-instagram-logo text-2xl"></i></a>
        <a href="#" class="hover:text-lucerna-accent transition-colors duration-300"><i class="ph ph-linkedin-logo text-2xl"></i></a>
      </div>
    </div>
  </div>
</footer>
